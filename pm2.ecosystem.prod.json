{
  "apps": [
    {
      "name": "scoreforge-api-prod",
      "script": "-m",
      "args": "uvicorn api.main:app --host 0.0.0.0 --port 8000 --workers 1",
      "interpreter": "python3",
      "cwd": "/home/deployer/scoreforge",
      "env": {
        "JOB_STORE_TYPE": "sqlite",
        "JOB_STORE_PATH": "/home/deployer/scoreforge/data/jobs.db",
        "PORT": "8000"
      },
      "max_memory_restart": "1G",
      "merge_logs": true,
      "autorestart": true,
      "kill_timeout": 5000,
      "listen_timeout": 10000,
      "graceful_shutdown": true
    }
  ]
}
